#!/bin/sh
# Sensitive-info guard (see .claude/rules/sensitive-info.md). Blocks a commit that would introduce
# a dev-machine path or private family data (names, DOBs, bookings, trip specifics) into this repo.
# The repo history was reset on 2026-07-13 precisely to remove such leaks — keep it clean.
# Install with: git config core.hooksPath devtools/hooks
# Bypass intentionally with: git commit --no-verify
node devtools/scripts/check-sensitive.mjs
