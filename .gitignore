# .NET
bin/
obj/
publish/
*.user

# Gatherlight.Resources — the assembled driver/binary payload (built from the driver; never committed)
src/resources/*/payload/

# Node / client
node_modules/
dist/
build/
.vite/
*.tsbuildinfo
*.log

# data folder — ALL user data (plans, household, SQLite, uploads, caches, history archive).
# Default GATHERLIGHT_DATA location; has its own private git repo inside. Never tracked here.
local/
local-clean/
local-*/

# SQLite app state — NEVER tracked, anywhere (belt-and-suspenders; the data folder is already
# ignored above + the data repo ignores state/). The DB now also holds the knowledge library, so
# it is a source of truth — but it stays OUT of git and is backed up with the data folder, not here.
*.db
*.db-wal
*.db-shm
*.sqlite
*.sqlite3

# Exported memory bundles — contain user knowledge (library/facts); transfer them, don't commit.
gatherlight-memory*.json

# built client (src/client `npm run build` output)
src/server/Gatherlight.Server/wwwroot/

# devtools throwaways + captures + generated fixtures
devtools/screenshots/
devtools/_*
devtools/.cdp-port

# legacy viewer runtime leftovers (until viewer/ is deleted in Phase 4)
.uploads/
.tmp/
.tmp-*
.puppeteer-cache/
.cache/
.env
.env.local
.env.*.local

# Claude Code personal settings (rules/skills ARE tracked)
.claude/settings.local.json
.claude/scheduled_tasks.lock
.claude/plans/

# OS / IDE
Thumbs.db
.DS_Store
desktop.ini
.vscode/
.vs/
.idea/
*.swp
*.swo
*~
