        ".claude/templates/daily.md",
        ".claude/workflows/STORAGE.md",
        "household/constraints.md",
        "household/recurring.md"
      ],
      "lite": true
    },
    {
      "key": "weekly",
      "match": ["周计划", "本周", "下周", "plan-week", "weekly", "周回顾"],
