        ".claude/templates/weekly.md",
        ".claude/workflows/STORAGE.md",
        "household/constraints.md",
        "household/recurring.md",
        "household/preferences.md"
      ],
      "lite": true
    },
    {
      "key": "budget",
      "match": ["预算", "budget", "花费统计", "开销记录"],
